meta {
  name: Delete AI Integration
  type: graphql
  seq: 5
}

docs {
  Delete an AI integration.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteAIIntegration($id: ID!) {
    aiIntegrationDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "AI_INTEGRATION_ID_HERE"
  }
}
