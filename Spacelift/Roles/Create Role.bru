meta {
  name: Create Role
  type: graphql
  seq: 3
}

docs {
  Create a new Role.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation CreateRole($input: RoleInput!) {
    roleCreate(input: $input) {
      id
      name
      slug
      description
      actions
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "name": "my-role",
      "description": "Custom role",
      "actions": []
    }
  }
}
