meta {
  name: Create API Key Role Binding
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation CreateApiKeyRoleBinding($input: ApiKeyRoleBindingInput!) {
    apiKeyRoleBindingCreate(input: $input) {
      id
      apiKeyID
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "apiKeyID": "API_KEY_ID_HERE",
      "roleID": "ROLE_ID_HERE",
      "spaceID": "root"
    }
  }
}
