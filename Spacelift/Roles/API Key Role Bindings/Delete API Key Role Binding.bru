meta {
  name: Delete API Key Role Binding
  type: graphql
  seq: 5
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteApiKeyRoleBinding($id: ID!) {
    apiKeyRoleBindingDelete(id: $id) {
      id
      apiKeyID
    }
  }
}

body:graphql:vars {
  {
    "id": "ROLE_BINDING_ID_HERE"
  }
}
