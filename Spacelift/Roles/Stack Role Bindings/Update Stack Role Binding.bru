meta {
  name: Update Stack Role Binding
  type: graphql
  seq: 4
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation UpdateStackRoleBinding($id: ID!, $input: StackRoleBindingUpdateInput!) {
    stackRoleBindingUpdate(id: $id, input: $input) {
      id
      stackID
      stackName
    }
  }
}

body:graphql:vars {
  {
    "id": "ROLE_BINDING_ID_HERE",
    "input": {
      "roleID": "ROLE_ID_HERE"
    }
  }
}
