meta {
  name: Create Stack Role Binding
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation CreateStackRoleBinding($input: StackRoleBindingInput!) {
    stackRoleBindingCreate(input: $input) {
      id
      stackID
      stackName
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "stackID": "STACK_ID_HERE",
      "roleID": "ROLE_ID_HERE",
      "spaceID": "root"
    }
  }
}
