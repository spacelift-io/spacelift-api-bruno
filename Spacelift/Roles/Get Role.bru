meta {
  name: Get Role
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetRole($id: ID!) {
    role(id: $id) {
      id
      name
      slug
      description
      isSystem
      actions
      roleBindingsCount
    }
  }
}

body:graphql:vars {
  {
    "id": "ROLE_ID_HERE"
  }
}
