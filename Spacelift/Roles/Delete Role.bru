meta {
  name: Delete Role
  type: graphql
  seq: 5
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteRole($id: ID!) {
    roleDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "ROLE_ID_HERE"
  }
}
