meta {
  name: Create User Role Binding
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation CreateUserRoleBinding($input: UserRoleBindingInput!) {
    userRoleBindingCreate(input: $input) {
      id
      roleID
      userID
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "userID": "USER_ID_HERE",
      "roleID": "ROLE_ID_HERE",
      "spaceID": "root"
    }
  }
}
