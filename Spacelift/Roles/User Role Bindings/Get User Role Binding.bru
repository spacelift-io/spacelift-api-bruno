meta {
  name: Get User Role Binding
  type: graphql
  seq: 1
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetUserRoleBinding($id: ID!) {
    userRoleBinding(id: $id) {
      id
      roleID
      userID
    }
  }
}

body:graphql:vars {
  {
    "id": "ROLE_BINDING_ID_HERE"
  }
}
