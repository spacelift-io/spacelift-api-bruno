meta {
  name: Reset VCS Agent Pool
  type: graphql
  seq: 6
}

docs {
  Recreate the credentials necessary to connect VCSAgentPool's agents to the gateways.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation ResetVCSAgentPool($id: ID!) {
    vcsAgentPoolReset(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "VCS_AGENT_POOL_ID_HERE"
  }
}
