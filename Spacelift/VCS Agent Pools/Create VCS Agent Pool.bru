meta {
  name: Create VCS Agent Pool
  type: graphql
  seq: 3
}

docs {
  Create a new VCSAgentPool.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation CreateVcsAgentPool($name: String!, $description: String) {
    vcsAgentPoolCreate(name: $name, description: $description) {
      id
      name
      description
    }
  }
}

body:graphql:vars {
  {
    "name": "my-vcs-agent-pool",
    "description": "My VCS agent pool"
  }
}
