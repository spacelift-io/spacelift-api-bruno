meta {
  name: Delete VCS Agent Pool
  type: graphql
  seq: 5
}

docs {
  Delete an existing VCSAgentPool.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteVcsAgentPool($id: ID!) {
    vcsAgentPoolDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "VCS_AGENT_POOL_ID_HERE"
  }
}
