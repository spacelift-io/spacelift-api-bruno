meta {
  name: Revoke Provider Version
  type: graphql
  seq: 12
}

docs {
  Revoke a published Terraform provider version.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation RevokeTerraformProviderVersion($version: ID!) {
    terraformProviderVersionRevoke(version: $version) {
      id
      number
      status
    }
  }
}

body:graphql:vars {
  {
    "version": "PROVIDER_VERSION_ID_HERE"
  }
}
