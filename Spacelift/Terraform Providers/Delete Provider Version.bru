meta {
  name: Delete Provider Version
  type: graphql
  seq: 10
}

docs {
  Delete a draft Terraform provider version.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteTerraformProviderVersion($version: ID!) {
    terraformProviderVersionDelete(version: $version) {
      id
      number
      deleted
    }
  }
}

body:graphql:vars {
  {
    "version": "PROVIDER_VERSION_ID_HERE"
  }
}
