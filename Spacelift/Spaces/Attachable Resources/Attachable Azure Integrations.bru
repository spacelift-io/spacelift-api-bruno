meta {
  name: Attachable Azure Integrations
  type: graphql
  seq: 2
}

docs {
  List of azure integrations that can be attached Stacks/Modules in given space.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query AttachableAzureIntegrationsInSpace($id: ID!) {
    attachableAzureIntegrationsInSpace(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "SPACE_ID_HERE"
  }
}
