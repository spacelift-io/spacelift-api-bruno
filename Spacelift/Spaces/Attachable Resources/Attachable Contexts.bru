meta {
  name: Attachable Contexts
  type: graphql
  seq: 3
}

docs {
  List of contexts that can be attached Stacks/Modules in given space.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query AttachableContextsInSpace($id: ID!) {
    attachableContextsInSpace(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "SPACE_ID_HERE"
  }
}
