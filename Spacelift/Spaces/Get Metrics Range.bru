meta {
  name: Get Metrics Range
  type: graphql
  seq: 8
}

docs {
  Return the values for a given metric in a given range.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetMetricsRange($input: MetricsInput) {
    metricsRange(input: $input) {
      hasStacks
      hasRuns
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "startTime": 1700000000,
      "endTime": 1710000000
    }
  }
}
