meta {
  name: Disable Module
  type: graphql
  seq: 8
}

docs {
  Disable the module, so it cannot create new runs.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DisableModule($id: ID!) {
    moduleDisable(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "MODULE_ID_HERE"
  }
}
