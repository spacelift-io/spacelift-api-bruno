meta {
  name: Enable Module
  type: graphql
  seq: 7
}

docs {
  Enable the module.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation EnableModule($id: ID!) {
    moduleEnable(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "MODULE_ID_HERE"
  }
}
