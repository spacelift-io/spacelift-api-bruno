meta {
  name: Publish Module
  type: graphql
  seq: 6
}

docs {
  Change Terraform registry from private to public.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation PublishModule($id: ID!) {
    modulePublish(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "MODULE_ID_HERE"
  }
}
