meta {
  name: Delete Policy
  type: graphql
  seq: 5
}

docs {
  Delete an existing Policy.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeletePolicy($id: ID!) {
    policyDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "POLICY_ID_HERE"
  }
}
