meta {
  name: Get Policy
  type: graphql
  seq: 2
}

docs {
  Details of a single Policy.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetPolicy($id: ID!) {
    policy(id: $id) {
      id
      name
      body
      type
      description
      labels
      space
      createdAt
      updatedAt
    }
  }
}

body:graphql:vars {
  {
    "id": "POLICY_ID_HERE"
  }
}
