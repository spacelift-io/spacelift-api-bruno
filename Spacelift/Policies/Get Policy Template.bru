meta {
  name: Get Policy Template
  type: graphql
  seq: 10
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetPolicyTemplate($id: ID!) {
    policyTemplate(id: $id) {
      id
      name
      slug
      type
      body
      description
      labels
    }
  }
}

body:graphql:vars {
  {
    "id": "POLICY_TEMPLATE_ID_HERE"
  }
}
