meta {
  name: Delete Plugin
  type: graphql
  seq: 5
}

docs {
  Delete an existing Plugin.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeletePlugin($id: ID!) {
    pluginDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "PLUGIN_ID_HERE"
  }
}
