meta {
  name: Search Worker Pools
  type: graphql
  seq: 7
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query SearchWorkerPools($input: SearchInput!) {
    searchWorkerPools(input: $input) {
      edges {
        node {
          id
          name
          description
          labels
        }
      }
      pageInfo {
        hasNextPage
        endCursor
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "first": 50
    }
  }
}
