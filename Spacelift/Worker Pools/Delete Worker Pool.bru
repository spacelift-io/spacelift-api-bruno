meta {
  name: Delete Worker Pool
  type: graphql
  seq: 5
}

docs {
  Delete an existing WorkerPool.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteWorkerPool($id: ID!) {
    workerPoolDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "WORKER_POOL_ID_HERE"
  }
}
