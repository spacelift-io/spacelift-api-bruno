meta {
  name: Upload Local Workspace
  type: graphql
  seq: 22
}

docs {
  Upload workspace for later processing in other mutations.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation UploadLocalWorkspace($stack: ID!) {
    uploadLocalWorkspace(stack: $stack) {
      id
      uploadUrl
    }
  }
}

body:graphql:vars {
  {
    "stack": "STACK_ID_HERE"
  }
}
