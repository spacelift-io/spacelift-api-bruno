meta {
  name: Delete API Key
  type: graphql
  seq: 5
}

docs {
  Delete an API key.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteApiKey($id: ID!) {
    apiKeyDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "API_KEY_ID_HERE"
  }
}
