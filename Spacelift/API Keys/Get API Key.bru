meta {
  name: Get API Key
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetApiKey($id: ID!) {
    apiKey(id: $id) {
      id
      name
      admin
      description
      isMachineUser
      expiresAt
      createdAt
      lastUsedAt
    }
  }
}

body:graphql:vars {
  {
    "id": "API_KEY_ID_HERE"
  }
}
