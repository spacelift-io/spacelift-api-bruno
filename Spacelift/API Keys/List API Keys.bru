meta {
  name: List API Keys
  type: graphql
  seq: 1
}

docs {
  List of all API keys for the account.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  {
    apiKeys {
      id
      name
      admin
      description
      isMachineUser
      expiresAt
      createdAt
      lastUsedAt
    }
  }
}
