meta {
  name: Search Tofu Workspaces
  type: graphql
  seq: 1
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query SearchTofuWorkspaces($input: SearchInput!) {
    searchTofuWorkspaces(input: $input) {
      edges {
        node {
          id
          name
          isLocked
          lockedBy
          createdAt
        }
      }
      pageInfo {
        hasNextPage
        endCursor
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "first": 50
    }
  }
}
