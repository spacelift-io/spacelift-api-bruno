meta {
  name: Search Resources by Provider
  type: graphql
  seq: 4
}

docs {
  Search managed entities grouped by providers with a set of predicates, ordering and paging.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query SearchResourcesByProvider($input: SearchInput!) {
    searchManagedEntitiesGroupByProviders(input: $input) {
      edges {
        node {
          id
          count
        }
      }
      pageInfo {
        hasNextPage
        endCursor
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "first": 50
    }
  }
}
