meta {
  name: Get OpenTofu Effective Version
  type: graphql
  seq: 3
}

docs {
  Given version constraints, calculate the latest version that satisfies it.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetOpenTofuEffectiveVersion($constraints: String!) {
    openTofuEffectiveVersion(constraints: $constraints)
  }
}

body:graphql:vars {
  {
    "constraints": ">= 1.6.0"
  }
}
