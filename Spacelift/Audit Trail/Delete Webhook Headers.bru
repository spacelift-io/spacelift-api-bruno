meta {
  name: Delete Webhook Headers
  type: graphql
  seq: 6
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteAuditTrailWebhookHeaders($input: AuditTrailWebhookDeleteHeadersInput!) {
    auditTrailWebhookDeleteHeaders(input: $input) {
      enabled
      endpoint
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "keys": ["X-Custom-Header"]
    }
  }
}
