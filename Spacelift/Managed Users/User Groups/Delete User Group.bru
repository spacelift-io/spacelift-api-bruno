meta {
  name: Delete User Group
  type: graphql
  seq: 5
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteUserGroup($id: ID!) {
    managedUserGroupDelete(id: $id) {
      id
      groupName
    }
  }
}

body:graphql:vars {
  {
    "id": "USER_GROUP_ID_HERE"
  }
}
