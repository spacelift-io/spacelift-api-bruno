meta {
  name: Update User Group
  type: graphql
  seq: 4
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation UpdateUserGroup($input: ManagedUserGroupUpdateInputV2!) {
    managedUserGroupUpdateV2(input: $input) {
      id
      groupName
      description
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "id": "USER_GROUP_ID_HERE",
      "description": "Updated description"
    }
  }
}
