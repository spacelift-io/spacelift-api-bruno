meta {
  name: Delete User Group Integration
  type: graphql
  seq: 10
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteUserGroupIntegration($id: ID!) {
    managedUserGroupIntegrationDelete(id: $id) {
      id
      integrationName
    }
  }
}

body:graphql:vars {
  {
    "id": "USER_GROUP_INTEGRATION_ID_HERE"
  }
}
