meta {
  name: Invite Managed User
  type: graphql
  seq: 3
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation InviteManagedUser($input: ManagedUserInviteInputV2!) {
    managedUserInviteV2(input: $input) {
      id
      username
      invitationEmail
      status
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "email": "user@example.com",
      "username": "myuser"
    }
  }
}
