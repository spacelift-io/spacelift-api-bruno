meta {
  name: Request Role Change
  type: graphql
  seq: 8
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation ManagedUserRequestRoleChange($spaceId: ID!, $requestedAccessLevel: SpaceAccessLevel!) {
    managedUserRequestRoleChange(spaceId: $spaceId, requestedAccessLevel: $requestedAccessLevel)
  }
}

body:graphql:vars {
  {
    "spaceId": "SPACE_ID_HERE",
    "requestedAccessLevel": "READ"
  }
}
