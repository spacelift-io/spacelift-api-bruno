meta {
  name: List Managed Users
  type: graphql
  seq: 1
}

docs {
  List of users that were invited or logged into the account.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  {
    managedUsers {
      id
      username
      invitationEmail
      loginMethod
      status
      lastLoginTime
    }
  }
}
