meta {
  name: Delete Context
  type: graphql
  seq: 5
}

docs {
  Delete an existing context.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteContext($id: ID!) {
    contextDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "CONTEXT_ID_HERE"
  }
}
