meta {
  name: Delete Dependency
  type: graphql
  seq: 3
}

docs {
  Delete a stack dependency.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteStackDependency($id: ID!) {
    stackDependencyDelete(id: $id) {
      id
      triggerAlways
    }
  }
}

body:graphql:vars {
  {
    "id": "DEPENDENCY_ID_HERE"
  }
}
