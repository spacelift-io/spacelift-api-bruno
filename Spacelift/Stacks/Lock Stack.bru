meta {
  name: Lock Stack
  type: graphql
  seq: 10
}

docs {
  Lock the stack for exclusive use.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation LockStack($id: ID!, $note: String) {
    stackLock(id: $id, note: $note) {
      id
      name
      lockedAt
      lockedBy
      lockNote
    }
  }
}

body:graphql:vars {
  {
    "id": "STACK_ID_HERE",
    "note": "Locked for maintenance"
  }
}
