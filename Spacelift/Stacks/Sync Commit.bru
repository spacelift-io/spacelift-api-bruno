meta {
  name: Sync Commit
  type: graphql
  seq: 20
}

docs {
  Sync the tracked commit of the stack.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation SyncStackCommit($id: ID!) {
    stackSyncCommit(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "STACK_ID_HERE"
  }
}
