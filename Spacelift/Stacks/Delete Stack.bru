meta {
  name: Delete Stack
  type: graphql
  seq: 5
}

docs {
  Delete an existing stack.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteStack($id: ID!) {
    stackDelete(id: $id) {
      id
    }
  }
}

body:graphql:vars {
  {
    "id": "STACK_ID_HERE"
  }
}
