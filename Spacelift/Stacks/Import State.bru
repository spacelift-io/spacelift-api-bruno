meta {
  name: Import State
  type: graphql
  seq: 14
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation ImportState($stackId: ID!, $state: String!) {
    stackManagedStateImport(stackId: $stackId, state: $state)
  }
}

body:graphql:vars {
  {
    "stackId": "STACK_ID_HERE",
    "state": "BASE64_ENCODED_STATE_HERE"
  }
}
