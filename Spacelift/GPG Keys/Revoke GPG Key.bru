meta {
  name: Revoke GPG Key
  type: graphql
  seq: 4
}

docs {
  Revokes a GPG key to be used for signing binaries.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation RevokeGPGKey($id: ID!) {
    gpgKeyRevoke(id: $id) {
      id
      name
      revokedAt
    }
  }
}

body:graphql:vars {
  {
    "id": "GPG_KEY_ID_HERE"
  }
}
