meta {
  name: Get External Integration
  type: graphql
  seq: 2
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetExternalIntegration($id: ID!) {
    externalIntegration(id: $id) {
      id
      name
      description
      type
      createdAt
      deleted
    }
  }
}

body:graphql:vars {
  {
    "id": "EXTERNAL_INTEGRATION_ID_HERE"
  }
}
