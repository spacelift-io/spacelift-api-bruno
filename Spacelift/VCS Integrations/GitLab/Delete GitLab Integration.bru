meta {
  name: Delete GitLab Integration
  type: graphql
  seq: 4
}

docs {
  Deletes the GitLab integration.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteGitlabIntegration($id: ID) {
    gitlabIntegrationDelete(id: $id) {
      id
      name
      apiHost
    }
  }
}

body:graphql:vars {
  {
    "id": "INTEGRATION_ID_HERE"
  }
}
