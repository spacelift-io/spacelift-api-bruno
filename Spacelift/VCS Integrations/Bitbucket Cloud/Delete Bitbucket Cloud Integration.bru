meta {
  name: Delete Bitbucket Cloud Integration
  type: graphql
  seq: 4
}

docs {
  Deletes the Bitbucket Cloud integration.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteBitbucketCloudIntegration($id: ID) {
    bitbucketCloudIntegrationDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "INTEGRATION_ID_HERE"
  }
}
