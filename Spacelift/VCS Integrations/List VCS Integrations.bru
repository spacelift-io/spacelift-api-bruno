meta {
  name: List VCS Integrations
  type: graphql
  seq: 1
}

docs {
  List of all VCS integrations available in the account.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  {
    vcsIntegrations {
      id
      name
      provider
      isDefault
      space {
        id
        name
      }
    }
  }
}
