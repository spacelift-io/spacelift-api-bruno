meta {
  name: Test VCS Integration
  type: graphql
  seq: 6
}

docs {
  Runs a test to check whether the VCS integration is configured correctly
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query TestVCSIntegration($provider: VCSProvider!, $id: ID!) {
    vcsIntegrationTest(provider: $provider, id: $id) {
      status
    }
  }
}

body:graphql:vars {
  {
    "provider": "GITHUB_ENTERPRISE",
    "id": "VCS_INTEGRATION_ID_HERE"
  }
}
