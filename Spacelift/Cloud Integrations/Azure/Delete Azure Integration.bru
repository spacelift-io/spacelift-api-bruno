meta {
  name: Delete Azure Integration
  type: graphql
  seq: 5
}

docs {
  Deletes the integration with the specified ID.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteAzureIntegration($id: ID!) {
    azureIntegrationDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "AZURE_INTEGRATION_ID_HERE"
  }
}
