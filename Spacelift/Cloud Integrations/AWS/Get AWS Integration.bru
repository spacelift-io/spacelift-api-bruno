meta {
  name: Get AWS Integration
  type: graphql
  seq: 2
}

docs {
  Details of a single AWS integration.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  query GetAwsIntegration($id: ID!) {
    awsIntegration(id: $id) {
      id
      name
      roleArn
      generateCredentialsInWorker
      labels
      space
    }
  }
}

body:graphql:vars {
  {
    "id": "AWS_INTEGRATION_ID_HERE"
  }
}
