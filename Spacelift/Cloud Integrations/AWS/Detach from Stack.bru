meta {
  name: Detach from Stack
  type: graphql
  seq: 11
}

docs {
  Delete an AWS integration by unsetting a role ARN.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DetachAwsIntegrationFromStack($id: ID!) {
    stackIntegrationAwsDelete(id: $id) {
      activated
      assumedRoleArn
    }
  }
}

body:graphql:vars {
  {
    "id": "STACK_ID_HERE"
  }
}
