meta {
  name: Parse Blueprint Version Template
  type: graphql
  seq: 4
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation ParseBlueprintVersionTemplate($template: String!) {
    blueprintVersionParseTemplate(template: $template) {
      inputs {
        id
        name
        description
        type
      }
      errors
    }
  }
}

body:graphql:vars {
  {
    "template": "{}"
  }
}
