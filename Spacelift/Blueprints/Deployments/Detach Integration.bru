meta {
  name: Detach Integration
  type: graphql
  seq: 7
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DetachBlueprintIntegration($id: ID!) {
    blueprintDetachIntegration(id: $id) {
      id
      blueprintID
      blueprintName
      integrationID
      integrationName
      deleted
    }
  }
}

body:graphql:vars {
  {
    "id": "ATTACHMENT_ID_HERE"
  }
}
