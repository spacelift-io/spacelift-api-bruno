meta {
  name: Delete Blueprint
  type: graphql
  seq: 5
}

docs {
  Delete an existing blueprint.
}

post {
  url: {{SPACELIFT_ENDPOINT}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt}}
}

body:graphql {
  mutation DeleteBlueprint($id: ID!) {
    blueprintDelete(id: $id) {
      id
      name
    }
  }
}

body:graphql:vars {
  {
    "id": "BLUEPRINT_ID_HERE"
  }
}
